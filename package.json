{
  "name": "ody",
  "private": true,
  "workspaces": [
    "packages/*",
    "internal/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "build:cli": "bun run --filter '@ody/cli' build",
    "build:docs": "bun sync:schema && bun run --filter '@ody/docs' build",
    "dev:docs": "bun run --filter '@ody/docs' dev",
    "dev:desktop": "bun run --filter '@ody/desktop' start",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt --write .",
    "test": "bun run --filter '*' test",
    "typecheck": "bun run --filter '*' typecheck",
    "sync:schema": "bun run --filter '@ody/cli' gen:schema && cp ./packages/cli/dist/configuration_schema.json ./packages/docs/public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/bun": "^1.3.9",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
