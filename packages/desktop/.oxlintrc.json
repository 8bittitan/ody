{
  "$schema": "../../node_modules/oxlint/configuration_schema.json",
  "extends": ["../../.oxlintrc.json"],
  "plugins": ["unicorn", "typescript", "oxc", "react", "react-perf"],
  "ignorePatterns": ["**/routeTree.gen.ts"],
  "jsPlugins": [
    {
      "name": "react-hooks-js",
      "specifier": "eslint-plugin-react-hooks"
    }
  ],
  "rules": {
    "react-hooks-js/component-hook-factories": "warn",
    "react-hooks-js/config": "warn",
    "react-hooks-js/error-boundaries": "warn",
    "react-hooks-js/gating": "warn",
    "react-hooks-js/globals": "warn",
    "react-hooks-js/immutability": "error",
    "react-hooks-js/incompatible-library": "error",
    "react-hooks-js/preserve-manual-memoization": "error",
    "react-hooks-js/purity": "error",
    "react-hooks-js/refs": "error",
    "react-hooks-js/set-state-in-effect": "error",
    "react-hooks-js/set-state-in-render": "error",
    "react-hooks-js/static-components": "warn",
    "react-hooks-js/unsupported-syntax": "warn",
    "react-hooks-js/use-memo": "error",

    "react-hooks-js/void-use-memo": "error",

    "react-hooks-js/automatic-effect-dependencies": "error",
    "react-hooks-js/capitalized-calls": "warn",
    "react-hooks-js/fbt": "warn",
    "react-hooks-js/fire": "warn",
    "react-hooks-js/hooks": "error",
    "react-hooks-js/invariant": "warn",
    "react-hooks-js/memoized-effect-dependencies": "error",
    "react-hooks-js/no-deriving-state-in-effects": "error",
    "react-hooks-js/rule-suppression": "error",
    "react-hooks-js/syntax": "error",
    "react-hooks-js/todo": "warn"
  }
}
